# Base URL de la app
# Local: http://localhost:3000
# Produccion: https://tu-dominio.com
NEXTAUTH_URL=http://localhost:3000

# Genera un secreto largo y aleatorio. Ejemplo:
# openssl rand -base64 32
NEXTAUTH_SECRET=

# Google OAuth
# Redirect URI local: http://localhost:3000/api/auth/callback/google
# Redirect URI prod:  https://tu-dominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
# Valid OAuth Redirect URI local: http://localhost:3000/api/auth/callback/facebook
# Valid OAuth Redirect URI prod:  https://tu-dominio.com/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Formspree para avisos de ventas
FORMSPREE_VENTAS_ENDPOINT=https://formspree.io/f/xeenyryl

# SMTP para verificación de cuenta y recuperación de contraseña
# Con Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=centrokareh@gmail.com
# SMTP_PASS=tu-app-password-de-gmail
# MAIL_FROM="KAREH <centrokareh@gmail.com>"
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Base de datos
# Vercel Postgres suele inyectar POSTGRES_URL automáticamente en despliegue.
POSTGRES_URL=

# Mantenimiento
# Usalo solo para inicializar datos con POST /api/migrate
MIGRATION_SECRET=

# Debug admin APIs
# En produccion dejalo en false salvo que necesites diagnostico puntual
ENABLE_ADMIN_DEBUG_API=false
